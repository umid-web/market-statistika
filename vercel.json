{
  "version": 2,
  "framework": "vite",
  "buildCommand": "npm run build --prefix frontend-react",
  "outputDirectory": "frontend-react/dist",
  "installCommand": "npm install --prefix frontend-react",
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://web-production-1d28d4.up.railway.app/api/:path*"
    },
    {
      "source": "/((?!assets/).*)",
      "destination": "/index.html"
    }
  ]
}
