{
  "version": 2,
  "framework": "vite",
  "buildCommand": "npm run build --prefix frontend-react",
  "outputDirectory": "frontend-react/dist",
  "installCommand": "npm install --prefix frontend-react",
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "https://web-production-1d28d4.up.railway.app/api/$1"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ]
}
